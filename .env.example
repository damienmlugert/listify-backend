# Server
PORT=3001
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/listify

# Auth
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_UNLIMITED=price_YOUR_UNLIMITED_PRICE_ID

# Redis (for job queues - optional)
REDIS_URL=redis://localhost:6379

# App
FRONTEND_URL=https://listifyapp.com
MAX_FREE_LISTINGS=5
